{
  "name": "harun-karaca-fuel-station-prototype",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "postinstall": "npm run db:generate --workspace apps/api",
    "dev": "concurrently \"npm:dev --workspace apps/api\" \"npm:dev --workspace apps/web\"",
    "build": "npm run build --workspace apps/api && npm run build --workspace apps/web",
    "start": "npm run start --workspace apps/api",
    "test": "npm run test --workspace apps/api",
    "db:generate": "npm run db:generate --workspace apps/api",
    "db:migrate": "npm run db:migrate --workspace apps/api",
    "db:seed": "npm run db:seed --workspace apps/api",
    "db:studio": "npm run db:studio --workspace apps/api",
    "deploy:prepare": "npm run db:generate && npm run db:migrate",
    "deploy:seed": "npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
